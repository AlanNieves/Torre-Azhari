# ========================================
# CONFIGURACIÓN DEL BACKEND - TORRE AZHARI
# ========================================
# Copia este archivo a .env y llena los valores reales

# ═══════════════════════════════════════
# DATABASE
# ═══════════════════════════════════════
MONGO_URI=mongodb+srv://<usuario>:<password>@cluster.mongodb.net/azhari?retryWrites=true&w=majority

# ═══════════════════════════════════════
# SERVER
# ═══════════════════════════════════════
PORT=5000
NODE_ENV=production

# ═══════════════════════════════════════
# SECURITY & CORS
# ═══════════════════════════════════════
CORS_ORIGINS=https://www.azhari.com,https://azhari.com

# ═══════════════════════════════════════
# EMAIL (SMTP)
# ═══════════════════════════════════════
SEND_EMAIL=true
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
SALES_NOTIFY_TO=ventas@azhari.com

# ═══════════════════════════════════════
# LOGGING
# ═══════════════════════════════════════
LOG_LEVEL=info
